# ─────────────────────────────────────────────────────────────────────────────
# OpoPlan — Variables de entorno
# Copia este archivo a `.env` y rellena los valores. Todos son opcionales:
# si no se rellenan, la plataforma funciona en modo local/mock para desarrollo.
# Cada academia (organización) puede luego sobreescribir sus propias claves
# desde el panel de administrador (configuración → integraciones).
# ─────────────────────────────────────────────────────────────────────────────

# Servidor
PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=cambia-esto-en-produccion

# Cloud Storage — Cloudflare R2 (compatible S3) o cualquier S3
# Si están vacíos, los uploads se guardan en ./uploads/ (modo local).
STORAGE_PROVIDER=local                 # local | r2 | s3
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=                      # ej. https://<accountid>.r2.cloudflarestorage.com
STORAGE_PUBLIC_URL=                    # ej. https://files.opoplan.es  (para servir los archivos)
STORAGE_REGION=auto

# Email — Resend (recomendado, free tier 3.000/mes) o SMTP genérico
EMAIL_PROVIDER=mock                    # mock | resend | smtp
EMAIL_FROM="OpoPlan <noreply@opoplan.es>"
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# IA — Multi-proveedor (Gemini, OpenAI o Anthropic). Cada usuario puede aportar
# además su propia clave personal (transcripción ~20:53). El coste lo asume
# el usuario en ese caso.
AI_PROVIDER=mock                       # mock | gemini | openai | anthropic
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Stripe — sandbox / test mode
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Videoconferencia para tutorías reservadas (transcripción ~20:11). Si no se
# configura nada, las reservas se crean igualmente y el preparador puede
# compartir el enlace manualmente. Cada academia puede además sobreescribir
# desde su panel.
#
# - jitsi : NO requiere autenticación. Funciona out-of-the-box. Si quieres
#   instancia auto-hospedada pon su dominio en VIDEOCONFERENCE_ACCOUNT_ID,
#   ej. meet.mi-academia.es. Si lo dejas vacío usa meet.jit.si público.
# - zoom  : Server-to-Server OAuth. Crea una "Server-to-Server OAuth" app en
#   marketplace.zoom.us. Necesitas Account ID + Client ID + Client Secret.
# - meet  : Google Calendar API. Requiere refresh_token OAuth2 del
#   organizador (con scope https://www.googleapis.com/auth/calendar.events) +
#   Client ID + Client Secret de tu proyecto en Google Cloud Console.
# - teams : Microsoft Graph API. Requiere refresh_token OAuth2 (scope
#   OnlineMeetings.ReadWrite) + Client ID + Client Secret + Tenant ID.
VIDEOCONFERENCE_PROVIDER=              # vacío | jitsi | zoom | meet | teams
VIDEOCONFERENCE_API_KEY=                # client_id (zoom/meet/teams)
VIDEOCONFERENCE_CLIENT_SECRET=          # client_secret (zoom/meet/teams)
VIDEOCONFERENCE_ACCOUNT_ID=             # account_id (zoom) | tenant_id (teams) | dominio jitsi
VIDEOCONFERENCE_REFRESH_TOKEN=          # refresh_token OAuth2 (meet/teams)
VIDEOCONFERENCE_ACCESS_TOKEN=           # opcional, si tienes uno corto y vivo
